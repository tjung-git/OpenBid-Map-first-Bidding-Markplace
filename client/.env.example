# ---- Client Environment Variables ----

# API Base URL (backend server)
VITE_API_BASE=http://localhost:4000

# Prototype mode flag (should match server PROTOTYPE setting)
VITE_PROTOTYPE=TRUE

# Stripe Publishable Key (for client-side payment processing)
# Get this from your Stripe Dashboard: https://dashboard.stripe.com/test/apikeys
# Use test key (pk_test_...) for development
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Google Maps API Key (for location services)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# server base URL
VITE_API_BASE=https://openbid2107.web.app


