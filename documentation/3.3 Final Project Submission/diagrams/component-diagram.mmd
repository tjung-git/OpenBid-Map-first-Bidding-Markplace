    classDef serverStyle fill:#b2f2bb,stroke:#2f9e44,stroke-width:2px
    classDef adapterStyle fill:#fff3bf,stroke:#e67700,stroke-width:2px
    classDef externalStyle fill:#ffc9c9,stroke:#e03131,stroke-width:2px
    classDef pageStyle fill:#d0ebff,stroke:#1971c2,stroke-width:1px
    classDef routeStyle fill:#d8f5a2,stroke:#2f9e44,stroke-width:1px
    classDef mwStyle fill:#ffe8cc,stroke:#e8590c,stroke-width:1px
    classDef mockStyle fill:#fff3bf,stroke:#e67700,stroke-width:1px
    classDef realStyle fill:#d0ebff,stroke:#1971c2,stroke-width:1px

    class CLIENT clientStyle
    class SERVER serverStyle
    class ADAPTERS adapterStyle
    class EXTERNAL externalStyle
    class MapView,JobDetail,Messenger,Profile,Payment,AdminDash,MyBids,NewJob,UserReviews,UserPortfolio pageStyle
    class Nav,ProtectedApp,AdminRoute,NonAdminRoute,SearchAuto pageStyle
    class ApiJS,SessionJS,SocketJS,UseSession,ConfigJS pageStyle
    class AuthR,JobsR,BidsR,PayR,KYCR,MsgR,RevR,PortR,AdminR,UploadR routeStyle
    class ReqRole,ForbRole mwStyle
    class DBMock,AuthMock,PayMock,KYCMock mockStyle
    class DBReal,AuthReal,PayReal,KYCReal realStyle
    class Firestore,FireAuth,FireStore,Stripe,StripeID,GMaps,Duo externalStyle
